   :sha256 "040e7cba076a6755443c822911a0b4c00980ec9a313aab93711f3b7ac7ee4a88"
   :size 473
   :body "//! Implementation details for the `uuid` crate.\n//!\n//! This crate is not meant to be used directly. It\n//! allows `wasm32-unknown-unknown` users who aren't\n//! in a JS-enabled runtime to configure a source of\n//! randomness via `getrandom`:\n//!\n//! ```toml\n//! [dependencies.uuid]\n//! features = [\"v4\", \"rng-getrandom\"]\n//! ```\n\n#[doc(hidden)]\npub mod __private {\n    #[cfg(feature = \"getrandom\")]\n    pub use getrandom;\n\n    #[cfg(feature = \"rand\")]\n    pub use rand;\n}\n"} {:path "SECURITY.md"
